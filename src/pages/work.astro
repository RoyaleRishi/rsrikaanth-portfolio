---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkEntry from "../components/WorkEntry.astro";

const all = (await getCollection("work")).sort((a, b) => a.data.order - b.data.order);
const roles = all.filter((e) => e.data.kind === "role");
const projects = all.filter((e) => e.data.kind === "project");
---

<BaseLayout title="Work — Rishi Srikaanth" description="Experience and projects by Rishi Srikaanth.">
  <section class="container head-block">
    <p class="mono eyebrow">Work</p>
    <h1>What I've built</h1>
    <p class="prose lead">
      The roles and projects I'd point to first — most come with a number I'm
      proud of.
    </p>
  </section>

  <section class="container group">
    <h2 class="group-title">Experience</h2>
    {
      roles.map((e) => (
        <WorkEntry
          title={e.data.title}
          org={e.data.org}
          period={e.data.period}
          summary={e.data.summary}
          bullets={e.data.bullets}
          tech={e.data.tech}
          links={e.data.links}
        />
      ))
    }
  </section>

  <section class="container group">
    <h2 class="group-title">Projects</h2>
    {
      projects.map((e) => (
        <WorkEntry
          title={e.data.title}
          org={e.data.org}
          period={e.data.period}
          summary={e.data.summary}
          bullets={e.data.bullets}
          tech={e.data.tech}
          links={e.data.links}
        />
      ))
    }
  </section>
</BaseLayout>

<style>
  .head-block {
    padding-block: var(--space-5) var(--space-3);
  }
  .eyebrow {
    color: var(--marigold-ink);
    margin: 0 0 var(--space-2);
  }
  .lead {
    font-size: 1.3rem;
    color: var(--ink-mute);
    margin-top: var(--space-2);
  }
  .group {
    padding-top: var(--space-4);
  }
  .group-title {
    font-size: 1.1rem;
    font-family: var(--font-mono);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--green-soft);
    margin-bottom: 0;
  }
</style>
