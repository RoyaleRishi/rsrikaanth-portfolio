---
import BaseLayout from "../layouts/BaseLayout.astro";
import Doodle from "../components/Doodle.astro";

const facts = [
  "M.S. Artificial Intelligence, Northeastern · GPA 3.952",
  "B.Tech Computer Science, VIT University",
  "Based in Boston, MA",
];
---

<BaseLayout
  title="About"
  description="AI engineer in Boston. Roots in Kenya and Tamil Nadu. Interested in AI safety and cultural equity."
>
  <section class="container about">
    <Doodle name="tennis" size={70} style="bottom:1rem; left:1%; transform:rotate(-8deg);" />
    <div class="portrait">
      <img src="/images/portrait.jpg" alt="Rishi Srikaanth" width="1000" height="1150" />
      <ul class="facts">
        {facts.map((f) => <li class="mono">{f}</li>)}
      </ul>
    </div>

    <div class="body">
      <p class="mono eyebrow">About</p>
      <h1>Hi, I'm Rishi.</h1>
      <div class="prose">
        <p>
          I'm an AI engineer finishing my M.S. in AI at Northeastern. I design and deploy machine-learning pipelines -
          data systems and production-grade APIs.
        </p>
        <p>
          My roots run through <span class="mark">Kenya and India</span>.
          A multicultural perspective is probably the most pivotal things I bring
          to my problem solving: I assume there's always another vantage point worth
          taking.
        </p>
        <p>
          I'd happily talk for hours about progressing cultural equity and
          addressing socio-economic concerns in and with technology: especially AI safety.
          That's the work I want to stay close to.
        </p>
        <p>For fun, I play chess and tennis, and I love to sing along as I listen to music.</p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .about {
    position: relative;
    display: grid;
    gap: var(--space-4);
    padding-block: var(--space-5);
  }
  @media (min-width: 52rem) {
    .about {
      grid-template-columns: 0.85fr 1.15fr;
      gap: var(--space-5);
      align-items: start;
    }
  }
  .portrait img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center 25%;
    border-radius: 6px;
    filter: grayscale(0.08);
    border: 1px solid color-mix(in srgb, var(--ink) 12%, transparent);
  }
  .facts {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-1);
  }
  .facts li {
    color: var(--ink-mute);
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: 0.82rem;
  }
  .eyebrow {
    color: var(--marigold-ink);
    margin: 0 0 var(--space-2);
  }
</style>
