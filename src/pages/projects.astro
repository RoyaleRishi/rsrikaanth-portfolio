---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkEntry from "../components/WorkEntry.astro";
import Doodle from "../components/Doodle.astro";

const projects = (await getCollection("work"))
  .filter((e) => e.data.kind === "project")
  .sort((a, b) => a.data.order - b.data.order);

// Skills (from the résumé) arranged to loosely trace a constellation.
// `projects` lists the work each skill maps to; the first is the most relevant.
const skills = [
  { id: "python", label: "Python", x: 22, y: 16, projects: ["neuronote", "navigatio", "beam-me-up", "sentinel"] },
  { id: "nlp", label: "NLP", x: 11, y: 30, projects: ["neuronote"] },
  { id: "llms", label: "LLMs", x: 30, y: 30, projects: ["navigatio", "neuronote"] },
  { id: "postgres", label: "PostgreSQL", x: 25, y: 45, projects: ["neuronote"] },
  { id: "neo4j", label: "Neo4j", x: 33, y: 60, projects: ["neuronote"] },
  { id: "modeleval", label: "Model evaluation", x: 45, y: 70, ll: true, projects: ["sentinel", "beam-me-up"] },
  { id: "numpy", label: "NumPy", x: 58, y: 78, projects: ["beam-me-up", "sentinel"] },
  { id: "sklearn", label: "scikit-learn", x: 70, y: 73, projects: ["sentinel"] },
  { id: "docker", label: "Docker", x: 80, y: 62, ll: true, projects: ["neuronote"] },
  { id: "features", label: "Feature engineering", x: 86, y: 49, ll: true, projects: ["sentinel", "beam-me-up"] },
];
const edges = [
  ["nlp", "llms"], ["python", "llms"], ["llms", "postgres"], ["postgres", "neo4j"],
  ["neo4j", "modeleval"], ["modeleval", "numpy"], ["numpy", "sklearn"],
  ["sklearn", "docker"], ["docker", "features"],
];
const pos = Object.fromEntries(skills.map((s) => [s.id, s]));

// Scattered background stars (vague sky dust)
const dust = [
  [6, 12], [14, 48], [9, 64], [18, 82], [35, 10], [44, 38], [38, 88],
  [52, 18], [58, 50], [49, 60], [66, 14], [70, 44], [88, 24], [92, 70],
  [80, 88], [60, 92], [33, 74], [27, 16], [86, 40], [16, 36], [70, 62],
];
---

<BaseLayout title="Projects: Rishi Srikaanth" description="Selected projects, explorable by skill.">
  <section class="container head-block">
    <Doodle name="food" size={62} style="top:2rem; right:6%; transform:rotate(8deg);" />
    <p class="mono eyebrow">Projects</p>
    <h1>Things I've built</h1>
    <p class="prose lead">
      A sky of skills. Tap a star to light up the project where it does the most
      work.
    </p>
  </section>

  <section class="container">
    <div class="sky" data-constellation>
      <svg class="lines" viewBox="0 0 100 100" preserveAspectRatio="none" aria-hidden="true">
        {dust.map(([x, y]) => <circle class="dust" cx={x} cy={y} r="0.35" />)}
        {
          edges.map(([a, b]) => (
            <line x1={pos[a].x} y1={pos[a].y} x2={pos[b].x} y2={pos[b].y} data-edge={`${a} ${b}`} />
          ))
        }
      </svg>
      {
        skills.map((s) => (
          <button
            class:list={["node", "mono", s.ll && "node--lleft"]}
            type="button"
            data-skill={s.id}
            data-projects={s.projects.join(",")}
            aria-pressed="false"
            style={`left:${s.x}%; top:${s.y}%`}
          >
            <span class="node-dot" aria-hidden="true" />
            <span class="node-label">{s.label}</span>
          </button>
        ))
      }
      <p class="seebelow mono" data-indicator hidden aria-live="polite">
        Lit up below <span class="chev" aria-hidden="true">↓</span>
      </p>
    </div>
    <p class="hint mono" data-hint>10 skills · 4 projects</p>
  </section>

  <section class="container cards" data-cards>
    {
      projects.map((e) => (
        <div class="proj-card" data-project={e.id}>
          <span class="relevant mono" aria-hidden="true">Most relevant</span>
          <WorkEntry
            title={e.data.title}
            org={e.data.org}
            period={e.data.period}
            summary={e.data.summary}
            bullets={e.data.bullets}
            tech={e.data.tech}
            links={e.data.links}
          />
        </div>
      ))
    }
  </section>
</BaseLayout>

<script>
  function wire() {
    const root = document.querySelector<HTMLElement>("[data-constellation]");
    const cardsWrap = document.querySelector<HTMLElement>("[data-cards]");
    const hint = document.querySelector<HTMLElement>("[data-hint]");
    const indicator = document.querySelector<HTMLElement>("[data-indicator]");
    if (!root || !cardsWrap || root.dataset.wired) return;
    root.dataset.wired = "1";

    const nodes = Array.from(root.querySelectorAll<HTMLButtonElement>(".node"));
    const cards = Array.from(cardsWrap.querySelectorAll<HTMLElement>(".proj-card"));
    const edges = Array.from(root.querySelectorAll<SVGLineElement>("[data-edge]"));
    let active: string | null = null;

    function reset() {
      active = null;
      nodes.forEach((n) => n.setAttribute("aria-pressed", "false"));
      cards.forEach((c) => c.classList.remove("is-dim", "is-match", "is-primary"));
      edges.forEach((e) => e.classList.remove("is-lit"));
      if (indicator) indicator.hidden = true;
      if (hint) hint.textContent = "10 skills · 4 projects";
    }

    function select(skill: string, btn: HTMLButtonElement) {
      if (active === skill) {
        reset();
        return;
      }
      active = skill;
      const projects = (btn.dataset.projects || "").split(",").filter(Boolean);
      nodes.forEach((n) => n.setAttribute("aria-pressed", String(n.dataset.skill === skill)));
      cards.forEach((c) => {
        const id = c.dataset.project || "";
        const match = projects.includes(id);
        c.classList.toggle("is-match", match);
        c.classList.toggle("is-dim", !match);
        c.classList.toggle("is-primary", id === projects[0]);
      });
      edges.forEach((e) => {
        const pair = (e.dataset.edge || "").split(" ");
        e.classList.toggle("is-lit", pair.includes(skill));
      });
      if (indicator) indicator.hidden = false;
      if (hint)
        hint.textContent = `${btn.textContent?.trim()} → ${projects.length} project${projects.length > 1 ? "s" : ""}`;
    }

    nodes.forEach((n) => n.addEventListener("click", () => select(n.dataset.skill || "", n)));
  }
  wire();
  document.addEventListener("astro:page-load", wire);
</script>

<style>
  .head-block {
    position: relative;
    padding-block: var(--space-5) var(--space-3);
  }
  .eyebrow {
    color: var(--marigold-ink);
    margin: 0 0 var(--space-2);
  }
  .lead {
    font-size: 1.3rem;
    color: var(--ink-mute);
    margin-top: var(--space-2);
  }

  .sky {
    position: relative;
    height: 380px;
    margin-top: var(--space-2);
    border-radius: 14px;
    background: radial-gradient(120% 140% at 70% 0%, #1d3a30 0%, #122019 60%, #0d1712 100%);
    overflow: hidden;
    color: var(--on-ink);
  }
  .lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .dust {
    fill: #f7f4ec;
    opacity: 0.35;
  }
  .lines line {
    stroke: rgba(247, 244, 236, 0.22);
    stroke-width: 0.25;
    transition: stroke 200ms ease, stroke-width 200ms ease;
  }
  .lines line.is-lit {
    stroke: var(--marigold);
    stroke-width: 0.6;
  }
  .node {
    position: absolute;
    transform: translate(-50%, -50%);
    display: block;
    padding: 5px;
    background: none;
    border: 0;
    cursor: pointer;
  }
  .node-dot {
    display: block;
    width: 0.5rem;
    height: 0.5rem;
    border-radius: 50%;
    background: #f7f4ec;
    box-shadow: 0 0 6px rgba(247, 244, 236, 0.6);
    transition: background 160ms ease, box-shadow 160ms ease, transform 160ms ease;
  }
  .node-label {
    position: absolute;
    top: 50%;
    left: calc(100% - 2px);
    transform: translateY(-50%);
    font-size: 0.7rem;
    white-space: nowrap;
    color: color-mix(in srgb, var(--on-ink) 78%, transparent);
    transition: color 160ms ease;
  }
  .node--lleft .node-label {
    left: auto;
    right: calc(100% - 2px);
  }
  .node:hover .node-label {
    color: var(--on-ink);
  }
  .node:hover .node-dot {
    transform: scale(1.25);
  }
  .node[aria-pressed="true"] .node-label {
    color: var(--marigold);
  }
  .node[aria-pressed="true"] .node-dot {
    background: var(--marigold);
    box-shadow: 0 0 12px 2px rgba(244, 176, 25, 0.8);
    transform: scale(1.5);
  }
  .seebelow {
    position: absolute;
    left: 50%;
    bottom: 12px;
    transform: translateX(-50%);
    margin: 0;
    color: var(--marigold);
    background: rgba(13, 23, 18, 0.7);
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
  }
  .seebelow .chev {
    display: inline-block;
    animation: bob 1s ease-in-out infinite;
  }
  @keyframes bob {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(3px); }
  }
  .hint {
    color: var(--ink-mute);
    margin-top: var(--space-2);
  }

  .cards {
    padding-top: var(--space-3);
  }
  .proj-card {
    position: relative;
    transition: opacity 220ms ease;
  }
  .proj-card.is-dim {
    opacity: 0.32;
  }
  .proj-card.is-match :global(.entry) {
    border-top-color: var(--marigold);
  }
  .relevant {
    position: absolute;
    top: -0.7rem;
    left: 0;
    background: var(--marigold);
    color: #161410;
    padding: 0.2rem 0.7rem;
    border-radius: 999px;
    font-size: 0.68rem;
    opacity: 0;
    transition: opacity 200ms ease;
    pointer-events: none;
  }
  .proj-card.is-primary .relevant {
    opacity: 1;
  }

  @media (max-width: 720px) {
    .sky {
      height: auto;
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      padding: var(--space-3) var(--space-3) calc(var(--space-3) + 2rem);
    }
    .lines {
      display: none;
    }
    .node {
      position: static;
      transform: none;
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      border: 1px solid rgba(247, 244, 236, 0.25);
      border-radius: 999px;
      padding: 0.3rem 0.6rem;
    }
    .node-label,
    .node--lleft .node-label {
      position: static;
      transform: none;
      left: auto;
      right: auto;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .seebelow .chev {
      animation: none;
    }
    .proj-card,
    .node,
    .node-dot,
    .lines line,
    .relevant {
      transition: none;
    }
  }
</style>
