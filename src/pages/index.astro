---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import WorkEntry from "../components/WorkEntry.astro";
import FourPillars from "../components/FourPillars.astro";

const work = await getCollection("work");
const projects = work
  .filter((e) => e.data.kind === "project")
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
const roles = work
  .filter((e) => e.data.kind === "role")
  .sort((a, b) => a.data.order - b.data.order);

const latest = (await getCollection("writing", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
)[0];
---

<BaseLayout title="Rishi Srikaanth — AI Engineer">
  <section class="hero container">
    <p class="mono eyebrow">AI Engineer <span aria-hidden="true">/</span> Boston, MA</p>
    <h1>Rishi<br />Srikaanth</h1>
    <FourPillars />
  </section>

  <section class="band block-marigold">
    <div class="container">
      <p class="mono band-label">What I care about</p>
      <p class="band-line">
        Technology that takes <strong>cultural equity</strong> and
        <strong>AI safety</strong> as seriously as it takes performance.
      </p>
    </div>
  </section>

  <section class="container section">
    <div class="head">
      <h2>Selected projects</h2>
      <a class="mono more" href="/projects">All projects <span aria-hidden="true">→</span></a>
    </div>
    {
      projects.map((e) => (
        <WorkEntry
          title={e.data.title}
          org={e.data.org}
          period={e.data.period}
          summary={e.data.summary}
          bullets={e.data.bullets}
          tech={e.data.tech}
          links={e.data.links}
        />
      ))
    }
  </section>

  <section class="container section">
    <div class="head">
      <h2>Experience</h2>
      <a class="mono more" href="/experience">Full history <span aria-hidden="true">→</span></a>
    </div>
    <ul class="exp">
      {
        roles.map((e) => (
          <li>
            <span class="mono exp-period">{e.data.period}</span>
            <span class="exp-role">{e.data.title}</span>
            <span class="exp-org mono">{e.data.org}</span>
          </li>
        ))
      }
    </ul>
  </section>

  {
    latest && (
      <section class="container section">
        <div class="head">
          <h2>Writing</h2>
          <a class="mono more" href="/writing">
            All essays <span aria-hidden="true">→</span>
          </a>
        </div>
        <a class="latest" href={`/writing/${latest.id}`}>
          <h3>{latest.data.title}</h3>
          <p>{latest.data.description}</p>
        </a>
      </section>
    )
  }
</BaseLayout>

<style>
  .hero {
    padding-block: var(--space-5) var(--space-4);
  }
  .eyebrow {
    color: var(--marigold-ink);
    margin: 0 0 var(--space-2);
  }
  .hero h1 {
    margin-bottom: var(--space-4);
  }

  .band {
    margin-top: var(--space-4);
    padding-block: var(--space-5);
  }
  .band-label {
    margin: 0 0 var(--space-2);
    color: color-mix(in srgb, var(--ink) 62%, transparent);
  }
  .band-line {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.75rem, 4.5vw, 3rem);
    line-height: 1.04;
    letter-spacing: -0.02em;
    max-width: 18ch;
    margin: 0;
  }

  .section {
    padding-top: var(--space-5);
  }
  .head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-2);
    margin-bottom: var(--space-1);
  }
  .more {
    color: var(--ink-mute);
  }
  .more:hover {
    color: var(--ink);
  }

  .exp {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
  }
  .exp li {
    display: grid;
    grid-template-columns: 10rem 1fr auto;
    gap: var(--space-2);
    align-items: baseline;
    padding-block: var(--space-2);
    border-top: 1px solid color-mix(in srgb, var(--ink) 14%, transparent);
  }
  .exp-period {
    color: var(--ink-mute);
  }
  .exp-role {
    font-weight: 500;
    font-size: 1.1rem;
  }
  .exp-org {
    color: var(--green-soft);
    text-align: right;
  }
  @media (max-width: 640px) {
    .exp li {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }
    .exp-org {
      text-align: left;
    }
  }

  .latest {
    display: block;
    padding-top: var(--space-3);
    border-top: 1px solid color-mix(in srgb, var(--ink) 16%, transparent);
  }
  .latest h3 {
    margin: 0 0 var(--space-1);
    transition: color 160ms ease;
  }
  .latest:hover h3 {
    color: var(--vermilion);
  }
  .latest p {
    color: var(--ink-mute);
    max-width: var(--prose-max);
    margin: 0;
  }
</style>
