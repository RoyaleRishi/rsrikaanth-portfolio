---
import BaseLayout from "../layouts/BaseLayout.astro";
import FourPillars from "../components/FourPillars.astro";
import Doodle from "../components/Doodle.astro";

const facts = [
  "M.S. Artificial Intelligence, Northeastern · GPA 3.952",
  "B.Tech Computer Science, VIT University",
  "Based in Boston, MA",
];
---

<BaseLayout title="Rishi Srikaanth — AI Engineer">
  <section class="hero container">
    <div class="hero-text">
      <p class="mono eyebrow">AI Engineer <span aria-hidden="true">/</span> Boston, MA</p>
      <h1>Rishi<br />Srikaanth</h1>
    </div>
    <FourPillars class="hero-pillars" />
  </section>

  <section class="container about">
    <Doodle name="chess" size={58} style="top:1.5rem; right:3%; transform:rotate(-7deg);" />
    <p class="mono eyebrow">About</p>
    <div class="about-grid">
      <div class="portrait">
        <img src="/images/portrait.jpg" alt="Rishi Srikaanth" width="600" height="750" />
        <ul class="facts">
          {facts.map((f) => <li class="mono">{f}</li>)}
        </ul>
      </div>

      <dl class="notes">
        <div class="note">
          <dt class="mono">What I do</dt>
          <dd>
            AI engineer finishing my M.S. in AI at Northeastern. I build and deploy
            machine-learning pipelines — data systems and production-grade APIs.
          </dd>
        </div>
        <div class="note">
          <dt class="mono">Where I'm from</dt>
          <dd>
            My roots run through <span class="mark">Kenya and India</span>. The
            multicultural lens is the most pivotal thing I bring to a problem —
            there's always another vantage point worth taking.
          </dd>
        </div>
        <div class="note">
          <dt class="mono">Off the clock</dt>
          <dd>Chess, tennis, and singing along to whatever's playing.</dd>
        </div>
      </dl>
    </div>
  </section>

  <section class="band block-marigold">
    <Doodle name="tennis" size={88} style="top:50%; right:6%; transform:translateY(-50%) rotate(-10deg); opacity:0.28; color:#161410;" />
    <div class="container">
      <p class="mono band-label">What I care about</p>
      <p class="band-line">
        Technology that takes <strong>cultural equity</strong> and
        <strong>AI safety</strong> as seriously as it takes performance.
      </p>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-5);
    padding-block: var(--space-5) var(--space-4);
  }
  .eyebrow {
    color: var(--marigold-ink);
    margin: 0 0 var(--space-2);
  }
  .hero-text h1 {
    margin-bottom: 0;
  }
  .hero-pillars {
    justify-self: end;
  }
  @media (max-width: 760px) {
    .hero {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .hero-pillars {
      justify-self: start;
    }
  }

  .about {
    position: relative;
    display: grid;
    gap: var(--space-4);
    padding-block: var(--space-4) var(--space-5);
  }
  @media (min-width: 52rem) {
    .about {
      grid-template-columns: 0.8fr 1.2fr;
      gap: var(--space-5);
      align-items: start;
    }
  }
  .portrait img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center 25%;
    border-radius: 6px;
    filter: grayscale(0.08);
    border: 1px solid color-mix(in srgb, var(--ink) 14%, transparent);
  }
  .facts {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    display: grid;
    gap: var(--space-1);
  }
  .facts li {
    color: var(--ink-mute);
    text-transform: none;
    letter-spacing: 0.02em;
    font-size: 0.82rem;
  }

  .band {
    position: relative;
    overflow: hidden;
    margin-top: var(--space-4);
    padding-block: var(--space-5);
  }
  .band-label {
    margin: 0 0 var(--space-2);
    color: color-mix(in srgb, #161410 62%, transparent);
  }
  .band-line {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.75rem, 4.5vw, 3rem);
    line-height: 1.04;
    letter-spacing: -0.02em;
    max-width: 18ch;
    margin: 0;
  }
</style>
