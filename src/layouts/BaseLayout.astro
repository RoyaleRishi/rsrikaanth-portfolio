---
import "../styles/global.css";
import { ClientRouter } from "astro:transitions";
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Rishi Srikaanth, AI Engineer." } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      (function () {
        function apply() {
          try {
            var t = localStorage.getItem("theme");
            if (!t) t = matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : "light";
            document.documentElement.dataset.theme = t;
          } catch (e) {}
        }
        apply();
        document.addEventListener("astro:after-swap", apply);
      })();
    </script>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="canonical" href={canonical} />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <ClientRouter />
  </head>
  <body>
    <div id="page-cover" aria-hidden="true" transition:persist="page-cover">
      <div class="cover-pillars">
        <!-- Peacock · Creativity -->
        <svg viewBox="0 0 88 88" class="cover-pillar" style="animation-delay:0ms">
          <ellipse cx="44" cy="24" rx="12" ry="16" fill="var(--green)" fill-opacity="0.16" stroke="currentColor" stroke-width="2"/>
          <ellipse cx="44" cy="26" rx="6.5" ry="9.5" fill="var(--marigold)"/>
          <circle cx="44" cy="28" r="3" fill="currentColor"/>
          <path d="M44,40 C44,55 42,68 44,82" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
            <path d="M44,52 L35,47"/><path d="M44,52 L53,47"/>
            <path d="M44,62 L36,58"/><path d="M44,62 L52,58"/>
            <path d="M44,72 L37,69"/><path d="M44,72 L51,69"/>
          </g>
        </svg>
        <!-- Maasai shield · Accountability -->
        <svg viewBox="0 0 88 88" class="cover-pillar" style="animation-delay:110ms">
          <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.7">
            <path d="M16,80 L70,14"/><path d="M72,80 L18,14"/>
          </g>
          <path d="M44,7 C58,13 61,30 56,47 C53,61 50,74 44,82 C38,74 35,61 32,47 C27,30 30,13 44,7 Z" fill="var(--paper)" stroke="currentColor" stroke-width="2"/>
          <path d="M44,12 L44,77" stroke="var(--vermilion)" stroke-width="2.4"/>
          <path d="M34,30 Q44,37 55,30" fill="none" stroke="var(--vermilion)" stroke-width="2"/>
          <path d="M33,58 Q44,51 56,58" fill="none" stroke="var(--vermilion)" stroke-width="2"/>
        </svg>
        <!-- Baobab · Authenticity -->
        <svg viewBox="0 0 88 88" class="cover-pillar" style="animation-delay:220ms">
          <path d="M30,82 L58,82" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M35,82 C34,64 33,52 38,45" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
          <path d="M53,82 C54,64 55,52 50,45" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"/>
          <g fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
            <path d="M44,46 C40,37 30,34 23,30"/>
            <path d="M44,46 C44,35 41,26 39,17"/>
            <path d="M44,46 C48,36 53,29 56,22"/>
            <path d="M44,46 C50,40 61,37 67,33"/>
            <path d="M44,46 C42,40 35,38 29,38"/>
          </g>
          <g fill="var(--green)">
            <circle cx="22" cy="29" r="2.2"/><circle cx="39" cy="16" r="2.2"/><circle cx="68" cy="32" r="2.2"/>
          </g>
        </svg>
        <!-- Rising sun · Wonder -->
        <svg viewBox="0 0 88 88" class="cover-pillar" style="animation-delay:330ms">
          <path d="M14,62 L74,62" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
          <path d="M28,62 A16,16 0 0 1 60,62 Z" fill="var(--marigold)"/>
          <g stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
            <path d="M44,40 L44,33"/><path d="M30,47 L26,42"/><path d="M58,47 L62,42"/>
            <path d="M36,42 L33,36"/><path d="M52,42 L55,36"/>
          </g>
          <g fill="var(--marigold)">
            <path d="M20,22 l1.4,3.4 l3.4,1.4 l-3.4,1.4 l-1.4,3.4 l-1.4,-3.4 l-3.4,-1.4 l3.4,-1.4 Z"/>
            <path d="M66,16 l1.1,2.7 l2.7,1.1 l-2.7,1.1 l-1.1,2.7 l-1.1,-2.7 l-2.7,-1.1 l2.7,-1.1 Z"/>
          </g>
        </svg>
      </div>
    </div>
    <a href="#main" class="sr-only">Skip to content</a>
    <Nav />
    <main id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<script>
  const cover = document.getElementById("page-cover");

  function hideCover() {
    if (!cover || cover.classList.contains("cover-out")) return;
    cover.classList.add("cover-out");
    cover.addEventListener("transitionend", () => cover.classList.add("cover-gone"), { once: true });
  }

  // Reveal after fonts + images are loaded
  window.addEventListener("load", () => setTimeout(hideCover, 100));

  // On ClientRouter navigation, hide immediately (persisted node keeps classes)
  document.addEventListener("astro:before-preparation", hideCover);

  // Animate main content in on each page navigation
  document.addEventListener("astro:after-swap", () => {
    const main = document.getElementById("main");
    if (!main) return;
    main.classList.remove("page-entering");
    void main.offsetWidth;
    main.classList.add("page-entering");
  });
</script>
