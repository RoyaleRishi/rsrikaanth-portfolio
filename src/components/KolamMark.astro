---
interface Props {
  size?: number;
  class?: string;
}
const { size = 160, class: className = "" } = Astro.props;
---

<svg
  class:list={["kolam", className]}
  width={size}
  height={size}
  viewBox="0 0 200 200"
  role="img"
  aria-label="A kolam — a single continuous line looping around a grid of dots"
>
  <defs>
    <pattern id="kolam-pulli" width="26" height="26" patternUnits="userSpaceOnUse">
      <circle cx="2" cy="2" r="1.5" fill="currentColor" opacity="0.22"></circle>
    </pattern>
  </defs>
  <rect x="0" y="0" width="200" height="200" fill="url(#kolam-pulli)"></rect>
  <path
    class="kolam-line"
    pathLength="1"
    d="M100,100 C70,68 70,32 100,32 C130,32 130,68 100,100 Z M100,100 C132,70 168,70 168,100 C168,130 132,130 100,100 Z M100,100 C70,132 70,168 100,168 C130,168 130,132 100,100 Z M100,100 C68,70 32,70 32,100 C32,130 68,130 100,100 Z"
    fill="none"
    stroke="currentColor"
    stroke-width="2.4"
    stroke-linejoin="round"
  ></path>
  <circle cx="100" cy="32" r="5" fill="var(--marigold)"></circle>
  <circle cx="168" cy="100" r="5" fill="currentColor"></circle>
  <circle cx="100" cy="168" r="5" fill="var(--marigold)"></circle>
  <circle cx="32" cy="100" r="5" fill="currentColor"></circle>
  <circle cx="100" cy="100" r="5" fill="var(--vermilion)"></circle>
</svg>

<style>
  .kolam-line {
    stroke-dasharray: 1;
    stroke-dashoffset: 1;
    animation: kolam-draw 1600ms ease-in-out 200ms forwards;
  }
  @keyframes kolam-draw {
    to {
      stroke-dashoffset: 0;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .kolam-line {
      animation: none;
      stroke-dashoffset: 0;
    }
  }
</style>
