---
const year = new Date().getFullYear();
const links = [
  { href: "mailto:srikaanth.r@northeastern.edu", label: "Email" },
  { href: "https://github.com/RoyaleRishi", label: "GitHub" },
  { href: "https://www.linkedin.com/in/rishisrikaanth/", label: "LinkedIn" },
  { href: "/resume.pdf", label: "Résumé" },
];
---

<footer class="footer block-ink">
  <div class="container inner">
    <p class="cta">Let's talk.</p>
    <ul>
      {links.map((l) => (
        <li><a class="foot-link" href={l.href}>{l.label}</a></li>
      ))}
    </ul>
    <p class="fine mono">© {year} Rishi Srikaanth</p>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--space-7);
    padding-block: var(--space-5) var(--space-4);
  }
  .inner {
    display: grid;
    gap: var(--space-3);
  }
  .cta {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(2.25rem, 7vw, 4rem);
    letter-spacing: -0.025em;
    line-height: 1;
    margin: 0;
  }
  ul {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: var(--space-3) 0 0;
    border-top: 1px solid color-mix(in srgb, var(--on-ink) 20%, transparent);
  }
  .foot-link {
    font-size: 1.05rem;
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    transition: border-color 160ms ease;
  }
  .foot-link:hover,
  .foot-link:focus-visible {
    border-color: var(--marigold);
  }
  .fine {
    color: color-mix(in srgb, var(--on-ink) 60%, transparent);
    margin: 0;
  }
</style>
