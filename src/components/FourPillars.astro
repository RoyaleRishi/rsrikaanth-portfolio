---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;

const pillars = [
  {
    key: "creativity",
    aria: "A peacock. Click to reveal its meaning.",
    pillar: "Creativity",
    title: "The peacock, mayil",
    blurb:
      "Mount of the Tamil deity Murugan and a centuries-old emblem of beauty and artistry across South India.",
    mine: "I like the solution nobody reached for first. Building, to me, is a craft before it's a deliverable.",
  },
  {
    key: "accountability",
    aria: "A Maasai shield. Click to reveal its meaning.",
    pillar: "Accountability",
    title: "The Maasai shield, olalem",
    blurb:
      "Painted in ochre, red, and white, it marks a warrior's family and age-set, and the duty to guard the community.",
    mine: "When the stakes are real, security, markets, I want to own what I ship, not just hand it off.",
  },
  {
    key: "authenticity",
    aria: "A fountain pen nib. Click to reveal its meaning.",
    pillar: "Authenticity",
    title: "The fountain pen",
    blurb:
      "The modern fountain pen came out of 19th-century Europe and America, and with it the idea that your handwritten signature is a binding mark of who you are. Ink goes down once; the line is honest about the hand that drew it.",
    mine: "Authenticity, to me, is writing in my own voice instead of the expected one.",
  },
  {
    key: "Wonder",
    aria: "A constellation of stars. Click to reveal its meaning.",
    pillar: "Wonder",
    title: "The night sky",
    blurb:
      "Every civilization has looked up and wondered about the same stars: One sky, read in a hundred ways.",
    mine: "Wonder is the habit of looking up and asking the next question; it's the thread that ties my worlds together.",
  },
];
---

<div class:list={["pillars-wrap", className]}>
  <div class="pillars" role="group" aria-label="Four symbols - click each to learn its story">
    {
      pillars.map((p, i) => (
        <button
          type="button"
          class="pillar"
          data-pillar={p.key}
          data-label={p.pillar}
          data-title={p.title}
          data-blurb={p.blurb}
          data-mine={p.mine}
          aria-label={p.aria}
          aria-expanded="false"
          aria-controls="pillar-card"
        >
          <span class="cue mono" aria-hidden="true">click me</span>
          {i === 0 && (
            <svg viewBox="0 0 88 88" aria-hidden="true">
              <ellipse cx="44" cy="24" rx="12" ry="16" fill="var(--green)" fill-opacity="0.16" stroke="currentColor" stroke-width="2" />
              <ellipse cx="44" cy="26" rx="6.5" ry="9.5" fill="var(--marigold)" />
              <circle cx="44" cy="28" r="3" fill="currentColor" />
              <path d="M44,40 C44,55 42,68 44,82" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
              <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
                <path d="M44,52 L35,47" /><path d="M44,52 L53,47" />
                <path d="M44,62 L36,58" /><path d="M44,62 L52,58" />
                <path d="M44,72 L37,69" /><path d="M44,72 L51,69" />
              </g>
            </svg>
          )}
          {i === 1 && (
            <svg viewBox="0 0 88 88" aria-hidden="true">
              <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.7">
                <path d="M16,80 L70,14" /><path d="M72,80 L18,14" />
              </g>
              <path d="M44,7 C58,13 61,30 56,47 C53,61 50,74 44,82 C38,74 35,61 32,47 C27,30 30,13 44,7 Z" fill="var(--paper)" stroke="currentColor" stroke-width="2" />
              <path d="M44,12 L44,77" stroke="var(--vermilion)" stroke-width="2.4" />
              <path d="M34,30 Q44,37 55,30" fill="none" stroke="var(--vermilion)" stroke-width="2" />
              <path d="M33,58 Q44,51 56,58" fill="none" stroke="var(--vermilion)" stroke-width="2" />
            </svg>
          )}
          {i === 2 && (
            <svg viewBox="0 0 88 88" aria-hidden="true">
              <path d="M34,16 L54,16 L50,56 L44,70 L38,56 Z" fill="var(--marigold)" fill-opacity="0.14" stroke="currentColor" stroke-width="2" stroke-linejoin="round" />
              <path d="M35,28 Q44,32 53,28" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" />
              <circle cx="44" cy="38" r="3.2" fill="var(--paper)" stroke="currentColor" stroke-width="2" />
              <path d="M44,41 L44,70" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
              <path d="M28,80 C38,74 50,86 60,77" fill="none" stroke="var(--vermilion)" stroke-width="2" stroke-linecap="round" />
            </svg>
          )}
          {i === 3 && (
            <svg viewBox="0 0 88 88" aria-hidden="true">
              <path d="M22,30 L40,46 L58,24 L70,42 L52,62 L34,58 L40,46" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round" opacity="0.5" />
              <g fill="var(--marigold)">
                <circle cx="40" cy="46" r="3" /><circle cx="58" cy="24" r="2.6" />
              </g>
              <g fill="currentColor">
                <circle cx="22" cy="30" r="2.2" /><circle cx="70" cy="42" r="2.2" />
                <circle cx="52" cy="62" r="2.2" /><circle cx="34" cy="58" r="2.2" />
              </g>
              <path d="M67,60 l1.3,3.2 l3.2,1.3 l-3.2,1.3 l-1.3,3.2 l-1.3,-3.2 l-3.2,-1.3 l3.2,-1.3 Z" fill="var(--green)" />
            </svg>
          )}
        </button>
      ))
    }
  </div>

  <div id="pillar-card" class="card" data-card hidden>
    <p class="mono card-pillar" data-card-pillar></p>
    <p class="card-title" data-card-title></p>
    <p class="card-blurb" data-card-blurb></p>
    <p class="mono card-mine-label">What it means to me</p>
    <p class="card-mine" data-card-mine></p>
  </div>
</div>

<script>
  function wire() {
    const root = document.querySelector<HTMLElement>(".pillars-wrap");
    if (!root || root.dataset.wired) return;
    root.dataset.wired = "1";

    const buttons = Array.from(root.querySelectorAll<HTMLButtonElement>(".pillar"));
    const card = root.querySelector<HTMLElement>("[data-card]");
    const elPillar = root.querySelector<HTMLElement>("[data-card-pillar]");
    const elTitle = root.querySelector<HTMLElement>("[data-card-title]");
    const elBlurb = root.querySelector<HTMLElement>("[data-card-blurb]");
    const elMine = root.querySelector<HTMLElement>("[data-card-mine]");
    if (!card || !elPillar || !elTitle || !elBlurb || !elMine) return;
    let open: string | null = null;

    function close() {
      open = null;
      card.hidden = true;
      buttons.forEach((b) => b.setAttribute("aria-expanded", "false"));
    }

    function show(btn: HTMLButtonElement) {
      btn.classList.remove("cue-on");
      const key = btn.dataset.pillar || "";
      if (open === key) {
        close();
        return;
      }
      open = key;
      elPillar.textContent = btn.dataset.label || "";
      elTitle.textContent = btn.dataset.title || "";
      elBlurb.textContent = btn.dataset.blurb || "";
      elMine.textContent = btn.dataset.mine || "";
      card.hidden = false;
      buttons.forEach((b) => b.setAttribute("aria-expanded", String(b === btn)));
    }

    buttons.forEach((b) => {
      let t: number | undefined;
      b.addEventListener("mouseenter", () => {
        t = window.setTimeout(() => b.classList.add("cue-on"), 900);
      });
      b.addEventListener("mouseleave", () => {
        if (t) window.clearTimeout(t);
        b.classList.remove("cue-on");
      });
      b.addEventListener("focus", () => b.classList.add("cue-on"));
      b.addEventListener("blur", () => b.classList.remove("cue-on"));
      b.addEventListener("click", () => show(b));
    });
  }
  wire();
  document.addEventListener("astro:page-load", wire);
</script>

<style>
  .pillars-wrap {
    display: grid;
    gap: var(--space-4);
    max-width: 100%;
  }
  .pillars {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-5);
    justify-content: center;
  }
  .pillar {
    position: relative;
    background: none;
    border: 0;
    padding: 0.25rem;
    cursor: pointer;
    color: var(--ink);
    line-height: 0;
    border-radius: 8px;
  }
  .pillar svg {
    width: 104px;
    height: 104px;
    display: block;
    transition: transform 160ms ease;
  }
  .pillar:hover svg,
  .pillar:focus-visible svg {
    animation: pillar-shake 600ms ease;
  }
  .pillar[aria-expanded="true"] svg {
    transform: scale(1.06);
  }
  .cue {
    position: absolute;
    bottom: calc(100% - 2px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--ink);
    color: var(--paper);
    font-size: 0.62rem;
    padding: 0.18rem 0.45rem;
    border-radius: 999px;
    line-height: 1.2;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity 180ms ease;
  }
  .pillar.cue-on .cue {
    opacity: 1;
  }

  .card {
    border-left: 3px solid var(--marigold);
    background: color-mix(in srgb, var(--paper) 60%, transparent);
    padding: var(--space-2) var(--space-3);
    border-radius: 0 8px 8px 0;
    max-width: 34rem;
  }
  .card-pillar {
    color: var(--marigold-ink);
    margin: 0 0 0.25rem;
  }
  .card-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.1rem;
    margin: 0 0 0.35rem;
  }
  .card-blurb {
    margin: 0 0 var(--space-2);
    color: color-mix(in srgb, var(--ink) 82%, transparent);
    line-height: 1.5;
  }
  .card-mine-label {
    color: var(--green-soft);
    margin: 0 0 0.2rem;
  }
  .card-mine {
    margin: 0;
    line-height: 1.5;
  }

  @keyframes pillar-shake {
    0%, 100% { transform: rotate(0deg); }
    20% { transform: rotate(-7deg); }
    40% { transform: rotate(6deg); }
    60% { transform: rotate(-4deg); }
    80% { transform: rotate(3deg); }
  }
  @media (prefers-reduced-motion: reduce) {
    .pillar:hover svg,
    .pillar:focus-visible svg {
      animation: none;
    }
    .pillar svg,
    .cue {
      transition: none;
    }
  }
</style>
