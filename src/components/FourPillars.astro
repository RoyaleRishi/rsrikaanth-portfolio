---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<div class:list={["pillars", className]} role="img" aria-label="Four pillars: creativity, accountability, authenticity, and wonder">
  <!-- Creativity — peacock feather (Tamil) -->
  <svg class="pillar" viewBox="0 0 88 88" aria-hidden="true">
    <ellipse cx="44" cy="24" rx="12" ry="16" fill="var(--green)" fill-opacity="0.16" stroke="currentColor" stroke-width="2"></ellipse>
    <ellipse cx="44" cy="26" rx="6.5" ry="9.5" fill="var(--marigold)"></ellipse>
    <circle cx="44" cy="28" r="3" fill="currentColor"></circle>
    <path d="M44,40 C44,55 42,68 44,82" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
    <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
      <path d="M44,52 L35,47"></path><path d="M44,52 L53,47"></path>
      <path d="M44,62 L36,58"></path><path d="M44,62 L52,58"></path>
      <path d="M44,72 L37,69"></path><path d="M44,72 L51,69"></path>
    </g>
  </svg>

  <!-- Accountability — Maasai shield & spears (Kenya) -->
  <svg class="pillar" viewBox="0 0 88 88" aria-hidden="true">
    <g stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity="0.7">
      <path d="M16,80 L70,14"></path><path d="M72,80 L18,14"></path>
    </g>
    <path d="M44,7 C58,13 61,30 56,47 C53,61 50,74 44,82 C38,74 35,61 32,47 C27,30 30,13 44,7 Z" fill="var(--paper)" stroke="currentColor" stroke-width="2"></path>
    <path d="M44,12 L44,77" stroke="var(--vermilion)" stroke-width="2.4"></path>
    <path d="M34,30 Q44,37 55,30" fill="none" stroke="var(--vermilion)" stroke-width="2"></path>
    <path d="M33,58 Q44,51 56,58" fill="none" stroke="var(--vermilion)" stroke-width="2"></path>
  </svg>

  <!-- Authenticity — baobab (East Africa) -->
  <svg class="pillar" viewBox="0 0 88 88" aria-hidden="true">
    <path d="M30,82 L58,82" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
    <path d="M35,82 C34,64 33,52 38,45" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"></path>
    <path d="M53,82 C54,64 55,52 50,45" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round"></path>
    <g fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round">
      <path d="M44,46 C40,37 30,34 23,30"></path>
      <path d="M44,46 C44,35 41,26 39,17"></path>
      <path d="M44,46 C48,36 53,29 56,22"></path>
      <path d="M44,46 C50,40 61,37 67,33"></path>
      <path d="M44,46 C42,40 35,38 29,38"></path>
    </g>
    <g fill="var(--green)">
      <circle cx="22" cy="29" r="2.2"></circle>
      <circle cx="39" cy="16" r="2.2"></circle>
      <circle cx="68" cy="32" r="2.2"></circle>
    </g>
  </svg>

  <!-- Wonder — rising sun & stars -->
  <svg class="pillar" viewBox="0 0 88 88" aria-hidden="true">
    <path d="M14,62 L74,62" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
    <path d="M28,62 A16,16 0 0 1 60,62 Z" fill="var(--marigold)"></path>
    <g stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
      <path d="M44,40 L44,33"></path>
      <path d="M30,47 L26,42"></path>
      <path d="M58,47 L62,42"></path>
      <path d="M36,42 L33,36"></path>
      <path d="M52,42 L55,36"></path>
    </g>
    <g fill="var(--marigold)">
      <path d="M20,22 l1.4,3.4 l3.4,1.4 l-3.4,1.4 l-1.4,3.4 l-1.4,-3.4 l-3.4,-1.4 l3.4,-1.4 Z"></path>
      <path d="M66,16 l1.1,2.7 l2.7,1.1 l-2.7,1.1 l-1.1,2.7 l-1.1,-2.7 l-2.7,-1.1 l2.7,-1.1 Z"></path>
    </g>
  </svg>
</div>

<style>
  .pillars {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-2);
    color: var(--ink);
    width: fit-content;
  }
  .pillar {
    width: 92px;
    height: 92px;
    border: 1px solid color-mix(in srgb, var(--ink) 14%, transparent);
    border-radius: 8px;
    padding: 8px;
    background: color-mix(in srgb, var(--paper) 60%, transparent);
    opacity: 0;
    transform: translateY(8px);
    animation: pillar-in 600ms ease forwards;
  }
  .pillar:nth-child(1) {
    animation-delay: 150ms;
  }
  .pillar:nth-child(2) {
    animation-delay: 300ms;
  }
  .pillar:nth-child(3) {
    animation-delay: 450ms;
  }
  .pillar:nth-child(4) {
    animation-delay: 600ms;
  }
  .pillar:hover {
    border-color: var(--marigold);
  }
  @keyframes pillar-in {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .pillar {
      opacity: 1;
      transform: none;
      animation: none;
    }
  }
</style>
